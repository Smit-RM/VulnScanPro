# VulnScan Pro — example configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and replace every placeholder with your own values.
#   cp .env.example .env
# NEVER commit the real .env (it is git-ignored). This file must contain
# placeholders ONLY — no real secrets.
# ---------------------------------------------------------------------------

# ============ Flask / crypto secrets (REQUIRED) ============
# Generate strong random values, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app REFUSES to start in production (FLASK_ENV/APP_ENV=production) if these
# are left at their built-in defaults.
SECRET_KEY=replace-me-with-a-long-random-string
JWT_SECRET_KEY=replace-me-with-a-different-long-random-string

# ============ Database ============
# Defaults to a local SQLite file at ./instance/vulnscanner.db when unset.
# Examples:
#   sqlite:///D:/Vulnscanpro/instance/vulnscanner.db
#   postgresql+psycopg2://user:password@localhost:5432/vulnscan
# DATABASE_URL=

# ============ Runtime / deployment ============
# FLASK_ENV / APP_ENV: set to "production" to enforce non-default secrets.
# FLASK_ENV=development
# APP_ENV=development
PORT=5000
# Bind address. Defaults to 127.0.0.1 (local only). Docker sets HOST=0.0.0.0.
# HOST=127.0.0.1

# Comma-separated CORS allowlist (never use "*"). Defaults to localhost:5000.
# CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# Public base URL used in password-reset / email-verification links.
APP_BASE_URL=http://127.0.0.1:5000

# bcrypt work factor (floor of 12 is enforced regardless of a lower value).
# BCRYPT_LOG_ROUNDS=12

# Require users to verify their email before logging in (1=on, 0=off).
# Set to 0 for local testing without SMTP configured.
REQUIRE_EMAIL_VERIFICATION=1

# ============ Async task backend (Celery + Redis) ============
# OPTIONAL. When REDIS_URL is set, scans run in a Celery worker and Socket.IO
# progress is relayed across processes via Redis. When UNSET (the default), scans
# run in an in-process background thread — no Redis or worker needed.
#   Web app:      python backend_app.py
#   Celery worker: celery -A backend_app.celery_app worker --pool=threads --concurrency=4
# REDIS_URL=redis://localhost:6379/0

# ============ Login throttle / account lockout ============
# All optional — sensible defaults are baked in. Shown here for reference.
LOGIN_RL_MAX=10                 # max login attempts per IP per window -> 429
# LOGIN_RL_WINDOW_SEC=60        # sliding window length (seconds)
# LOGIN_LOCK_THRESHOLD=5        # consecutive failures before account lock
# LOGIN_LOCK_DURATION_SEC=900   # lock length (15 minutes)
# LOGIN_DELAY_BASE_SEC=0.25     # progressive per-IP delay base
# LOGIN_DELAY_CAP_SEC=4.0       # progressive delay cap
# LOGIN_DELAY_JITTER_SEC=0.10   # random jitter added to the delay
# LOGIN_DELAY_DECAY_SEC=900     # reset an IP's delay streak after idle

# Trust the X-Forwarded-For header (only behind a proxy you control).
# TRUST_XFF=0
# TRUSTED_PROXY_COUNT=1         # number of proxy hops you own (right side of XFF)

# ============ SMTP / Email (optional — unset => email is a logged no-op) ============
# To send real email via Gmail:
#   1. SMTP_HOST=smtp.gmail.com
#   2. SMTP_PORT=587
#   3. SMTP_USER=your-full-gmail-address@gmail.com
#   4. SMTP_PASS=<16-char Google App Password>  (NOT your normal password)
#      Generate at: Google Account -> Security -> 2-Step Verification -> App passwords
#   5. SMTP_FROM=your-gmail-address@gmail.com
#   6. SMTP_TLS=1
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=your-address@gmail.com
# SMTP_TLS=1

# ============ OWASP ZAP Integration (optional — disabling is safe) ============
# When ZAP_API_URL is not set the /api/zap/* endpoints return HTTP 503 and
# every other feature of VulnScan Pro continues to work normally.
#
# LOCAL DEVELOPMENT (ZAP on the same machine, no tunnel required):
#   ZAP_API_URL=http://127.0.0.1:8080
#   ZAP_API_KEY=your-local-zap-api-key
#
# PRODUCTION (Render deployment — ZAP on a developer laptop):
#   1. Install cloudflared:  winget install Cloudflare.cloudflared
#   2. Run:  cloudflared tunnel --url http://localhost:8080
#   3. Copy the generated URL (e.g. https://xxxx.trycloudflare.com) below.
#   4. Add both variables to Render's environment dashboard — NOT to this file.
#   ZAP_API_URL=https://xxxx.trycloudflare.com
#   ZAP_API_KEY=replace-with-your-zap-api-key
#
# SECURITY RULES (enforced by zap_service.py):
#   • ZAP_API_KEY is NEVER placed in a URL, never logged, never sent to the browser.
#   • ZAP_API_URL is NEVER returned in any API response.
#   • The browser only ever calls /api/zap/* on the Flask backend.
#
# Timeout overrides — all optional:
# ZAP_CONNECT_TIMEOUT=10      # seconds to wait for initial ZAP connection
# ZAP_REQUEST_TIMEOUT=30      # seconds per individual ZAP API call
# ZAP_SPIDER_TIMEOUT=600      # max seconds to wait for spider (10 min)
# ZAP_PSCAN_TIMEOUT=120       # max seconds to wait for passive scan queue
# ZAP_ASCAN_TIMEOUT=3600      # max seconds to wait for active scan (60 min)
# ZAP_POLL_INTERVAL=5         # seconds between status polls

